{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "User account information and game statistics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "username": { "type": "string", "description": "Display name" },
        "email": { "type": "string", "description": "User email" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation date" },
        "highScore": { "type": "integer", "description": "Highest score achieved in games" }
      },
      "required": ["uid", "username", "email", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Individual user profile documents"
    }
  }
}
