rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "c0sm1c404044@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'totalHours', 'gameStats', 'updatedAt']) &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.totalHours is number && data.totalHours >= 0 &&
             data.gameStats is map;
    }

    // ===============================================================
    // User profiles
    // ===============================================================
    match /users/{userId} {
      // Anyone authenticated can read user profiles (for leaderboard)
      allow read: if isAuthenticated();
      
      // Only the owner or admin can create/update profiles
      allow create: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
                      
      allow update: if (isOwner(userId) || isAdmin()) && 
                      isValidUser(request.resource.data) &&
                      request.resource.data.username == resource.data.username; // Username immutable
    }
  }
}
