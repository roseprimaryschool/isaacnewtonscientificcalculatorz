{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Nova Media Network",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "The user's display name"
        },
        "totalHours": {
          "type": "number",
          "description": "Total hours played across all games"
        },
        "gameStats": {
          "type": "object",
          "description": "Map of gameId to hours played"
        },
        "coins": {
          "type": "number",
          "description": "The user's Nova Coins balance"
        },
        "ownedThemes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of theme IDs owned by the user"
        },
        "ownedTitles": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of title IDs owned by the user"
        },
        "activeTheme": {
          "type": "string",
          "description": "The current active theme ID"
        },
        "activeTitle": {
          "type": "string",
          "description": "The current active title ID"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last time the user's stats were updated"
        }
      },
      "required": ["username", "totalHours", "coins"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in the global chat",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "activeTitle": { "type": "string" },
        "activeAvatar": { "type": "string" }
      },
      "required": ["userId", "username", "text", "timestamp"]
    },
    "PrivateMessage": {
      "title": "PrivateMessage",
      "description": "A private message between two users",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderName", "text", "timestamp"]
    },
    "ChatRoom": {
      "title": "ChatRoom",
      "description": "A private chat room between two users",
      "type": "object",
      "properties": {
        "participants": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of user IDs in the chat"
        },
        "participantNames": {
          "type": "object",
          "description": "Map of userId to username"
        },
        "lastMessage": { "type": "string" },
        "lastTimestamp": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and stats"
    },
    "/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Global chat messages"
    },
    "/chatRooms/{roomId}": {
      "schema": "ChatRoom",
      "description": "Private chat rooms"
    },
    "/chatRooms/{roomId}/messages/{messageId}": {
      "schema": "PrivateMessage",
      "description": "Messages within a private chat room"
    }
  }
}
