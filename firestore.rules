rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "c0sm1c404044@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'totalHours', 'gameStats', 'updatedAt', 'coins']) &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.totalHours is number && data.totalHours >= 0 &&
             data.coins is number && data.coins >= 0 &&
             data.gameStats is map &&
             (!('ownedThemes' in data) || data.ownedThemes is list) &&
             (!('ownedTitles' in data) || data.ownedTitles is list) &&
             (!('activeTheme' in data) || data.activeTheme is string) &&
             (!('activeTitle' in data) || data.activeTitle is string);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['userId', 'username', 'text', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 500 &&
             (!('activeTitle' in data) || data.activeTitle is string) &&
             (!('activeAvatar' in data) || data.activeAvatar is string);
    }

    function isValidPrivateMessage(data) {
      return data.keys().hasAll(['senderId', 'senderName', 'receiverId', 'text', 'timestamp', 'participants']) &&
             data.senderId == request.auth.uid &&
             data.participants.size() == 2 &&
             request.auth.uid in data.participants &&
             data.receiverId in data.participants &&
             data.senderName is string && data.senderName.size() > 0 && data.senderName.size() < 50 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000;
    }

    // ===============================================================
    // User profiles
    // ===============================================================
    match /users/{userId} {
      // Allow public read for leaderboard and profile viewing
      allow read: if true;
      
      // Only the owner or admin can create/update profiles
      allow create: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
                      
      allow update: if (isOwner(userId) || isAdmin()) && 
                      isValidUser(request.resource.data) &&
                      request.resource.data.username == resource.data.username; // Username immutable
    }

    // ===============================================================
    // Global Chat
    // ===============================================================
    match /messages/{messageId} {
      // Anyone authenticated can read messages
      allow read: if isAuthenticated();
      
      // Only authenticated users can send messages, and they must be valid
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      
      // Only admins can delete or update messages
      allow update, delete: if isAdmin();
    }

    // ===============================================================
    // Private Chat
    // ===============================================================
    match /private_messages/{messageId} {
      // Only participants can read their private messages
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      // Only authenticated users can send private messages to valid participants
      allow create: if isAuthenticated() && isValidPrivateMessage(request.resource.data);
      
      // Only admins can delete private messages
      allow delete: if isAdmin();
    }
  }
}
